# =============================================================================
# NodeAlert IoT — Configuración de despliegue
# =============================================================================
# Copiar a .env y editar los valores según el entorno:
#   cp .env.example .env
#
# setup.sh leerá automáticamente este archivo si existe.
# Los valores aquí son los defaults del proyecto.
# =============================================================================

# ---------------------- RED WIFI ----------------------
# Credenciales de la red WiFi a la que se conectarán los ESP32.
WIFI_SSID=IC-2.4G
WIFI_PASS=1nf0rm4t1c4_2025

# ---------------------- BROKER MQTT ----------------------
# IP pública/accesible del broker Mosquitto (la que ven los ESP32).
MQTT_BROKER_IP=10.1.1.10

# Credenciales MQTT
MQTT_GATEWAY_USER=nodealert_gateway
MQTT_GATEWAY_PASS=test_password
MQTT_PUBLISHER_USER=mqtt_publisher
MQTT_PUBLISHER_PASS=test_password
MQTT_SUBSCRIBER_USER=mqtt_subscriber
MQTT_SUBSCRIBER_PASS=test_password

# ---------------------- FIRMWARE (ESP32) ----------------------
# Usuario MQTT dedicado para los ESP32 y su ID único.
MQTT_FIRMWARE_USER=nodealert_esp32
MQTT_FIRMWARE_PASS=test_password
FIRMWARE_DEVICE_ID=nodealert-01

# ---------------------- BASE DE DATOS (MySQL) ----------------------
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=nodealert
MYSQL_USER=nodealert
MYSQL_PASSWORD=db_password

# ---------------------- DJANGO ----------------------
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@nodealert.local
DJANGO_SUPERUSER_PASSWORD=admin_password
