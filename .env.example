# MQTT Broker
MQTT_BROKER_USER=nodealert_gateway
MQTT_BROKER_PASSWORD=changeme_secure_password

# MySQL Database
MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_DATABASE=nodealert
MYSQL_USER=nodealert
MYSQL_PASSWORD=changeme_db_password

# MQTT Subscriber (for Django management command)
MQTT_SUBSCRIBER_USER=mqtt_subscriber
MQTT_SUBSCRIBER_PASSWORD=changeme_subscriber_password

# Firmware MQTT (credentials for ESP32 node — generated by setup.sh)
FIRMWARE_MQTT_USER=nodealert_esp32
FIRMWARE_MQTT_PASSWORD=changeme_firmware_password
FIRMWARE_DEVICE_ID=nodealert-01

# Django
DJANGO_SECRET_KEY=changeme_generate_random_key
DJANGO_DEBUG=True
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@nodealert.local
DJANGO_SUPERUSER_PASSWORD=changeme_admin_password
