# Environment variables (contains credentials)
.env

# Mosquitto generated password files — NOT ignored for mosquitto/config/
# (empty placeholder is tracked so clone works; setup.sh overwrites it)
# Ignore any stray copies outside of mosquitto/config/
/mosquitto_passwd

# Python cache
__pycache__/
*.pyc

# VS Code
.vscode/

# macOS
.DS_Store

# Raspberry Pi — exclude firmware (ESP32, not needed on Pi)
NodeAlert-Firmware/
# Raspberry Pi — exclude planning docs (not needed on Pi)
.planning/

# Local development override — not for production (Raspberry Pi)
docker-compose.override.yml
