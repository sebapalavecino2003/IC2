<svg width="1360" height="1440" viewBox="0 0 680 720" xmlns="http://www.w3.org/2000/svg" style="font-family: Arial, sans-serif;">
  <title>Esquemático nodo periférico ESP32 - NodeAlert IoT</title>
  <rect width="680" height="720" fill="white"/>

  <defs>
    <marker id="arrow-green" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#1D9E75" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <marker id="arrow-amber" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#EF9F27" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <marker id="arrow-coral" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#D85A30" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <marker id="arrow-blue" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#378ADD" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <marker id="arrow-teal" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="#1D9E75" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
  </defs>

  <!-- Sensor region -->
  <rect x="20" y="20" width="180" height="370" rx="10" fill="#E1F5EE" stroke="#1D9E75" stroke-width="0.8" stroke-dasharray="5 3" opacity="0.8"/>
  <text x="110" y="38" text-anchor="middle" font-size="12" fill="#0F6E56" font-weight="600">Sensores</text>

  <!-- Power stage region -->
  <rect x="480" y="20" width="185" height="370" rx="10" fill="#FAECE7" stroke="#D85A30" stroke-width="0.8" stroke-dasharray="5 3" opacity="0.8"/>
  <text x="572" y="38" text-anchor="middle" font-size="12" fill="#993C1D" font-weight="600">Etapa de potencia</text>

  <!-- ESP32 -->
  <rect x="230" y="160" width="220" height="260" rx="8" fill="#E6F1FB" stroke="#185FA5" stroke-width="1"/>
  <text x="340" y="185" text-anchor="middle" font-size="14" fill="#0C447C" font-weight="700">ESP32</text>
  <text x="340" y="202" text-anchor="middle" font-size="11" fill="#185FA5">Dual-core · Wi-Fi · FreeRTOS</text>
  <text x="235" y="234" font-size="11" fill="#0C447C">GPIO4</text>
  <text x="235" y="264" font-size="11" fill="#0C447C">ADC34</text>
  <text x="235" y="294" font-size="11" fill="#0C447C">GPIO27</text>
  <text x="235" y="340" font-size="11" fill="#378ADD">3.3V</text>
  <text x="235" y="358" font-size="11" fill="#378ADD">5V IN</text>
  <text x="235" y="378" font-size="11" fill="#888780">GND</text>
  <text x="235" y="398" font-size="11" fill="#888780">GND</text>
  <text x="445" y="254" text-anchor="end" font-size="11" fill="#0C447C">GPIO18</text>
  <text x="445" y="294" text-anchor="end" font-size="11" fill="#0C447C">GPIO19</text>
  <text x="445" y="340" text-anchor="end" font-size="11" fill="#378ADD">TX/RX</text>
  <text x="445" y="378" text-anchor="end" font-size="11" fill="#888780">SDA/SCL</text>
  <circle cx="230" cy="232" r="3" fill="#185FA5"/>
  <circle cx="230" cy="262" r="3" fill="#185FA5"/>
  <circle cx="230" cy="292" r="3" fill="#185FA5"/>
  <circle cx="230" cy="338" r="3" fill="#378ADD"/>
  <circle cx="230" cy="358" r="3" fill="#378ADD"/>
  <circle cx="230" cy="378" r="3" fill="#888780"/>
  <circle cx="230" cy="398" r="3" fill="#888780"/>
  <circle cx="450" cy="252" r="3" fill="#185FA5"/>
  <circle cx="450" cy="292" r="3" fill="#185FA5"/>
  <circle cx="450" cy="338" r="3" fill="#378ADD"/>
  <circle cx="450" cy="378" r="3" fill="#888780"/>

  <!-- DHT22 -->
  <rect x="30" y="50" width="130" height="64" rx="6" fill="#E1F5EE" stroke="#1D9E75" stroke-width="0.8"/>
  <text x="95" y="74" text-anchor="middle" font-size="13" fill="#085041" font-weight="700">DHT22</text>
  <text x="95" y="92" text-anchor="middle" font-size="11" fill="#0F6E56">Temp · Humedad</text>
  <circle cx="160" cy="70" r="2.5" fill="#0F6E56"/>
  <circle cx="160" cy="84" r="2.5" fill="#1D9E75"/>
  <circle cx="160" cy="98" r="2.5" fill="#888780"/>
  <text x="165" y="73" font-size="10" fill="#085041">DATA</text>
  <text x="165" y="87" font-size="10" fill="#085041">VCC</text>
  <text x="165" y="101" font-size="10" fill="#5F5E5A">GND</text>
  <polyline points="160,70 200,70 200,232 230,232" fill="none" stroke="#1D9E75" stroke-width="1.3" marker-end="url(#arrow-green)"/>
  <polyline points="160,84 200,84 200,358 230,358" fill="none" stroke="#378ADD" stroke-width="0.9" stroke-dasharray="3 2" opacity="0.8"/>
  <polyline points="160,98 196,98 196,378 230,378" fill="none" stroke="#888780" stroke-width="0.9" stroke-dasharray="3 2" opacity="0.7"/>

  <!-- MQ-9 -->
  <rect x="30" y="185" width="130" height="64" rx="6" fill="#FAEEDA" stroke="#BA7517" stroke-width="0.8"/>
  <text x="95" y="209" text-anchor="middle" font-size="13" fill="#412402" font-weight="700">MQ-9</text>
  <text x="95" y="227" text-anchor="middle" font-size="11" fill="#854F0B">CO · Gas inflamable</text>
  <circle cx="160" cy="202" r="2.5" fill="#854F0B"/>
  <circle cx="160" cy="216" r="2.5" fill="#BA7517"/>
  <circle cx="160" cy="230" r="2.5" fill="#888780"/>
  <text x="165" y="205" font-size="10" fill="#633806">AOUT</text>
  <text x="165" y="219" font-size="10" fill="#633806">VCC</text>
  <text x="165" y="233" font-size="10" fill="#5F5E5A">GND</text>
  <polyline points="160,202 204,202 204,262 230,262" fill="none" stroke="#EF9F27" stroke-width="1.3" marker-end="url(#arrow-amber)"/>
  <polyline points="160,216 200,216 200,358 230,358" fill="none" stroke="#378ADD" stroke-width="0.9" stroke-dasharray="3 2" opacity="0.7"/>
  <polyline points="160,230 196,230 196,378 230,378" fill="none" stroke="#888780" stroke-width="0.9" stroke-dasharray="3 2" opacity="0.7"/>

  <!-- KY-026 -->
  <rect x="30" y="320" width="130" height="64" rx="6" fill="#FAECE7" stroke="#993C1D" stroke-width="0.8"/>
  <text x="95" y="344" text-anchor="middle" font-size="13" fill="#4A1B0C" font-weight="700">KY-026</text>
  <text x="95" y="362" text-anchor="middle" font-size="11" fill="#993C1D">Sensor de llama IR</text>
  <circle cx="160" cy="336" r="2.5" fill="#993C1D"/>
  <circle cx="160" cy="350" r="2.5" fill="#D85A30"/>
  <circle cx="160" cy="364" r="2.5" fill="#888780"/>
  <text x="165" y="339" font-size="10" fill="#712B13">DO (INT)</text>
  <text x="165" y="353" font-size="10" fill="#712B13">VCC</text>
  <text x="165" y="367" font-size="10" fill="#5F5E5A">GND</text>
  <polyline points="160,336 208,336 208,292 230,292" fill="none" stroke="#D85A30" stroke-width="1.5" marker-end="url(#arrow-coral)"/>
  <rect x="155" y="302" width="50" height="16" rx="3" fill="#FAECE7" stroke="#D85A30" stroke-width="0.5"/>
  <text x="180" y="314" text-anchor="middle" font-size="10" fill="#712B13" font-weight="700">IRQ</text>
  <polyline points="160,350 200,350 200,358 230,358" fill="none" stroke="#378ADD" stroke-width="0.9" stroke-dasharray="3 2" opacity="0.7"/>
  <polyline points="160,364 196,364 196,398 230,398" fill="none" stroke="#888780" stroke-width="0.9" stroke-dasharray="3 2" opacity="0.7"/>

  <!-- Transistor NPN -->
  <rect x="490" y="155" width="130" height="56" rx="6" fill="#FAECE7" stroke="#993C1D" stroke-width="0.8"/>
  <text x="555" y="178" text-anchor="middle" font-size="13" fill="#4A1B0C" font-weight="700">Transistor NPN</text>
  <text x="555" y="196" text-anchor="middle" font-size="11" fill="#993C1D">BC547 / 2N2222</text>
  <circle cx="490" cy="168" r="2.5" fill="#993C1D"/>
  <circle cx="490" cy="182" r="2.5" fill="#993C1D"/>
  <circle cx="490" cy="196" r="2.5" fill="#888780"/>
  <text x="484" y="171" text-anchor="end" font-size="10" fill="#712B13">Base</text>
  <text x="484" y="185" text-anchor="end" font-size="10" fill="#712B13">Col.</text>
  <text x="484" y="199" text-anchor="end" font-size="10" fill="#5F5E5A">Emit.</text>
  <polyline points="450,252 468,252 468,168 490,168" fill="none" stroke="#D85A30" stroke-width="1.3" marker-end="url(#arrow-coral)"/>
  <rect x="458" y="220" width="36" height="16" rx="3" fill="#FAECE7" stroke="#D85A30" stroke-width="0.5"/>
  <text x="476" y="232" text-anchor="middle" font-size="10" fill="#712B13">1kΩ</text>

  <!-- Diode -->
  <rect x="535" y="238" width="52" height="22" rx="4" fill="#F1EFE8" stroke="#888780" stroke-width="0.7" stroke-dasharray="3 2"/>
  <text x="561" y="253" text-anchor="middle" font-size="10" fill="#444441">D1 1N4007</text>

  <!-- Fan -->
  <rect x="490" y="280" width="130" height="56" rx="6" fill="#F1EFE8" stroke="#5F5E5A" stroke-width="0.8"/>
  <text x="555" y="303" text-anchor="middle" font-size="13" fill="#2C2C2A" font-weight="700">Ventilador DC</text>
  <text x="555" y="321" text-anchor="middle" font-size="11" fill="#5F5E5A">12V · 0.3A</text>
  <circle cx="490" cy="293" r="2.5" fill="#E24B4A"/>
  <circle cx="490" cy="307" r="2.5" fill="#888780"/>
  <text x="484" y="296" text-anchor="end" font-size="10" fill="#A32D2D">+12V</text>
  <text x="484" y="310" text-anchor="end" font-size="10" fill="#5F5E5A">GND</text>
  <polyline points="555,211 555,242 510,242 510,280" fill="none" stroke="#D85A30" stroke-width="1.2" marker-end="url(#arrow-coral)"/>

  <!-- Power supply -->
  <rect x="230" y="490" width="220" height="64" rx="6" fill="#EEEDFE" stroke="#534AB7" stroke-width="0.8"/>
  <text x="340" y="513" text-anchor="middle" font-size="13" fill="#26215C" font-weight="700">Fuente regulada</text>
  <text x="340" y="531" text-anchor="middle" font-size="11" fill="#534AB7">5V (ESP32) · 12V (ventilador)</text>
  <circle cx="230" cy="505" r="2.5" fill="#534AB7"/>
  <circle cx="230" cy="519" r="2.5" fill="#E24B4A"/>
  <circle cx="230" cy="533" r="2.5" fill="#888780"/>
  <text x="224" y="508" text-anchor="end" font-size="10" fill="#3C3489">5V</text>
  <text x="224" y="522" text-anchor="end" font-size="10" fill="#A32D2D">12V</text>
  <text x="224" y="536" text-anchor="end" font-size="10" fill="#5F5E5A">GND</text>
  <polyline points="230,505 180,505 180,440 220,440 220,358 230,358" fill="none" stroke="#378ADD" stroke-width="1.2" stroke-dasharray="4 2" marker-end="url(#arrow-blue)" opacity="0.9"/>
  <polyline points="230,533 184,533 184,450 224,450 224,398 230,398" fill="none" stroke="#888780" stroke-width="0.9" stroke-dasharray="3 2" opacity="0.7"/>
  <polyline points="450,519 460,519 460,460 510,460 510,336" fill="none" stroke="#E24B4A" stroke-width="1.1" stroke-dasharray="4 2" marker-end="url(#arrow-coral)" opacity="0.9"/>

  <!-- MQTT Gateway -->
  <rect x="245" y="622" width="190" height="52" rx="8" fill="#E1F5EE" stroke="#1D9E75" stroke-width="0.8"/>
  <text x="340" y="644" text-anchor="middle" font-size="13" fill="#04342C" font-weight="700">MQTT Broker</text>
  <text x="340" y="662" text-anchor="middle" font-size="11" fill="#0F6E56">Gateway · Raspberry Pi</text>
  <polyline points="340,554 340,622" fill="none" stroke="#1D9E75" stroke-width="1.3" stroke-dasharray="5 3" marker-end="url(#arrow-teal)" opacity="0.9"/>
  <rect x="308" y="575" width="64" height="17" rx="3" fill="#E1F5EE" stroke="#1D9E75" stroke-width="0.5"/>
  <text x="340" y="588" text-anchor="middle" font-size="10" fill="#085041" font-weight="600">Wi-Fi · MQTT</text>

  <!-- Legend -->
  <rect x="20" y="580" width="195" height="118" rx="6" fill="white" stroke="#D3D1C7" stroke-width="0.8"/>
  <text x="117" y="598" text-anchor="middle" font-size="12" fill="#2C2C2A" font-weight="700">Leyenda</text>
  <line x1="32" y1="615" x2="72" y2="615" stroke="#1D9E75" stroke-width="1.5"/>
  <text x="78" y="619" font-size="11" fill="#444441">Señal de sensor</text>
  <line x1="32" y1="633" x2="72" y2="633" stroke="#D85A30" stroke-width="1.5"/>
  <text x="78" y="637" font-size="11" fill="#444441">Control / activación</text>
  <line x1="32" y1="651" x2="72" y2="651" stroke="#378ADD" stroke-width="1.3" stroke-dasharray="4 2"/>
  <text x="78" y="655" font-size="11" fill="#444441">Alimentación 5V</text>
  <line x1="32" y1="669" x2="72" y2="669" stroke="#E24B4A" stroke-width="1.1" stroke-dasharray="4 2"/>
  <text x="78" y="673" font-size="11" fill="#444441">Alimentación 12V</text>
  <line x1="32" y1="687" x2="72" y2="687" stroke="#888780" stroke-width="0.9" stroke-dasharray="3 2"/>
  <text x="78" y="691" font-size="11" fill="#444441">GND</text>

  <!-- Footer -->
  <rect x="20" y="686" width="640" height="24" rx="4" fill="#E6F1FB" stroke="#185FA5" stroke-width="0.5"/>
  <text x="340" y="702" text-anchor="middle" font-size="11" fill="#0C447C" font-weight="500">NodeAlert IoT — Esquemático nodo periférico ESP32 | Universidad Nacional de Rafaela</text>
</svg>
